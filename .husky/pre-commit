#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Regenerate the public API snapshot before lint-staged.
# The breaking-change gate only runs here when the commit message is already
# known (e.g. git commit -m "...") so a BREAKING CHANGE footer can be
# respected. For interactive commits the message file does not exist yet;
# the commit-msg hook is the authoritative gate in that case.
if git diff --cached --name-only | grep -q '^src/components/'; then
  node ./scripts/types/check_types.mjs --update-only 2>/dev/null || {
    printf "✖ Running versioning check...\n"
    printf "versioning-check: failed to update types.json\n" >&2
    exit 1
  }
  git add types/carbon-react/types.json
  if [ -f ".git/COMMIT_EDITMSG" ]; then
    vc_tmpfile=$(mktemp)
    if node ./scripts/types/check_breaking_changes.mjs ".git/COMMIT_EDITMSG" \
      >"$vc_tmpfile" 2>&1; then
      printf "✔ Running versioning check...\n"
      rm -f "$vc_tmpfile"
    else
      printf "✖ Running versioning check...\n"
      cat "$vc_tmpfile"
      rm -f "$vc_tmpfile"
      exit 1
    fi
  else
    printf "✔ Running versioning check...\n"
  fi
fi

npx lint-staged
